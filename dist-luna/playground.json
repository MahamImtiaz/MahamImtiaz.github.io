{
  "name": "Animal Suika Playground",
  "version": "1.0.0",
  "description": "Playground configuration for Animal Suika game",
  "width": 1136,
  "height": 640,
  "orientation": "portrait",
  "entryPoint": "source.html",
  "startFunction": "startGame",
  "fields": {
    "GameSettings": {
      "timerCount": {
        "title": "Timer Count",
        "type": "int32",
        "defaultValue": 100,
        "section": "Game Settings",
        "order": 0,
        "constraints": { "value_min": 10, "value_max": 300, "value_step": 1 }
      },
      "noOfClicks": {
        "title": "Number of Clicks",
        "type": "int32",
        "defaultValue": 30,
        "section": "Game Settings",
        "order": 1,
        "constraints": { "value_min": 1, "value_max": 100, "value_step": 1 }
      },
      "numberOfAnimals": {
        "title": "Number of Animals",
        "type": "int32",
        "defaultValue": 10,
        "section": "Game Settings",
        "order": 2,
        "constraints": { "value_min": 3, "value_max": 10, "value_step": 1 }
      }
    }
  }
}

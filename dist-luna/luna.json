{
  "name": "Animal Suika",
  "version": "1.0.0",
  "description": "Animal Suika game playable ad",
  "width": 1136,
  "height": 640,
  "orientation": "portrait",
  "startFunction": "startGame",
  "entryPoint": "source.html",
  "parameters": {
    "timerCount": {
      "type": "number",
